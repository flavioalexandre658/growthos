{
  "functions": {
    "app/**": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/email-sequences",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/aggregate-and-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/evaluate-alerts",
      "schedule": "0 * * * *"
    }
  ]
}
